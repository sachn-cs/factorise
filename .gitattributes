# Global defaults
* text=auto

# Source code
*.py text eol=lf
*.pyi text eol=lf
*.sh text eol=lf executable

# Documentation
*.md text eol=lf
*.txt text eol=lf
LICENSE text eol=lf

# Configuration and manifests
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf
*.json text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf
MANIFEST.in text eol=lf
justfile text eol=lf

# Windows-specific scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.otf binary
