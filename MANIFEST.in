include LICENSE
include README.md
include CHANGELOG.md
include pyproject.toml
recursive-include factorise *.py *.typed
recursive-include tests *.py
recursive-include docs *.md
recursive-include benchmarks *.py
exclude setup.sh
exclude cleanup.sh
exclude .env.example
prune .benchmarks
prune .pytest_cache
prune dist
prune build
prune __pycache__
prune scratch
