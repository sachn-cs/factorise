# Factorise Local Environment Configuration

# Algorithm Tuning
# Increase to process fewer larger steps per iteration (impacts RAM slightly)
FACTORISE_BATCH_SIZE=256

# Maximum permitted steps to avoid infinite loops on prime-dense pathological inputs
FACTORISE_MAX_ITERATIONS=10000000

# Retries using fresh random seeds upon iteration exhaustion
FACTORISE_MAX_RETRIES=20

# System Logging (DEBUG, INFO, WARNING, ERROR)
FACTORISE_LOG_LEVEL=INFO
