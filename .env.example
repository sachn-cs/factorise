# factorise runtime configuration
# Copy to .env for local development:
#   cp .env.example .env

FACTORISE_BATCH_SIZE=128
FACTORISE_MAX_ITERATIONS=10000000
FACTORISE_MAX_RETRIES=20
# Optional deterministic seed for reproducible Pollard-Brent retries.
# FACTORISE_SEED=123456
FACTORISE_LOG_LEVEL=WARNING
FACTORISE_LOG_FORMAT=human

# Optional trace/correlation context fields used by JSON log mode.
# FACTORISE_REQUEST_ID=
# FACTORISE_CORRELATION_ID=
# FACTORISE_TRACE_ID=
# FACTORISE_SPAN_ID=
# FACTORISE_SESSION_ID=
